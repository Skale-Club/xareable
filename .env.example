# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application Configuration
APP_URL=https://xareable.com

# Database Configuration
DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=3000
NODE_ENV=development

# Stripe Configuration
# Use sk_test_... in development and sk_live_... in production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Use the endpoint signing secret from Stripe Dashboard or `stripe listen`
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AI Configuration (Phase 12.3 — DB-managed, no env required)
#
# GEMINI_API_KEY and OPENAI_API_KEY are NO LONGER read from env.
# Both are managed by admin in the app at /admin → Platform API Keys.
# Per-affiliate keys are stored on profiles.api_key / profiles.openai_api_key
# and set by the affiliate at /settings.
#
# Tier model:
#   - Admin    → uses platform_settings.gemini_api_key (shared)
#   - Affiliate→ uses profile.api_key (own)
#   - Regular  → uses platform_settings.gemini_api_key (shared, paid via credits)
